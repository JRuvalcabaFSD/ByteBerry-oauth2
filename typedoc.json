{
	"$schema": "https://typedoc.org/schema.json",
	"entryPoints": ["src"],
	"entryPointStrategy": "expand",
	"out": "docs",
	"exclude": [
		"**/*.test.ts",
		"**/*.spec.ts",
		"**/__tests__/**",
		"**/__mocks__/**"
	],
	"skipErrorChecking": true,
	"excludeInternal": true,
	"cleanOutputDir": true,
	"plugin": ["typedoc-plugin-markdown"],
	"readme": "none",

	"categorizeByGroup": false,

	"logLevel": "Warn",

	"validation": {
		"notDocumented": false,
		"invalidLink": true,
		"notExported": false
	}
}
