{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"outDir": "./dist",
		"declaration": true,
		"declarationMap": true,
		"removeComments": true,
		"noEmit": false,
		"rootDir": "." // ← aquí SÍ puedes poner "." porque hereda paths e include bien configurados
	},
	"include": ["src", "generated/prisma"],
	"exclude": ["node_modules", "dist", "tests", "**/*.spec.ts", "**/*.test.ts"]
}
