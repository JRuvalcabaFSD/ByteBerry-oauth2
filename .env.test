# ⚠️  Este archivo contiene configuración SOLO para integration tests
# ⚠️  NO usar en producción ni desarrollo

# Database para integration tests (PostgreSQL en Docker)
DATABASE_URL="postgresql://test_user:test_password@localhost:5433/oauth2_test?schema=public"

# Environment
NODE_ENV=test

# Logging (error solo para no saturar output de tests)
LOG_LEVEL=error

# Server (no se usa en tests, pero necesario para validación)
PORT=4000

