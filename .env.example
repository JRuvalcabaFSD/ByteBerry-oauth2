# ====================================
# ByteBerry OAuth2 Service - Environment Variables
# ====================================
# Fase: F0 - East Blue Saga (Bootstrap inicial)
# Servicio: OAuth2 (puerto 4000)
# ====================================

# ----------------
# Server Configuration
# 'development' | 'production' | 'test';
# ----------------
NODE_ENV=development
PORT=4000

# ----------------
# Logging Configuration
# 'debug' | 'info' | 'warn' | 'error'
# ----------------
LOG_LEVEL=info

# ----------------
# Application Metadata
# ----------------
SERVICE_NAME=byteberry-oauth2

# ----------------
# CORS Configuration (comma-separated list)
# ----------------
CORS_ORIGINS=<frontend dev Url>,<BFF>,<frontend prod url>

# ... existing variables ...

# ===================================
# JWT Configuration (T059)
# ===================================

# RSA Private Key (PEM format)
# Generate with: openssl genrsa -out private.pem 2048
# Use \n for line breaks or load from file
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"

# RSA Public Key (PEM format)
# Generate with: openssl rsa -in private.pem -pubout -out public.pem
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIB...\n-----END PUBLIC KEY-----"

# JWT Issuer (default: byteberry-oauth2)
JWT_ISSUER=byteberry-oauth2

# JWT Audience (default: byteberry-api)
JWT_AUDIENCE=byteberry-api

# Token expiration in seconds (default: 900 = 15 minutes)
JWT_EXPIRES_IN=900