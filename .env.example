# 🔐 ByteBerry OAuth2 Service - Environment Configuration
# Copy this file to .env and configure with your actual values

# ==========================================
# 🖥️  SERVER CONFIGURATION (F0)
# ==========================================

# Node.js environment (development | production | test)
NODE_ENV=development

# Server port (default: 4000 for OAuth2 service)
PORT=4000

# ==========================================
# 📊 LOGGING CONFIGURATION (F0)
# ==========================================

# Log level (debug | info | warn | error)
LOG_LEVEL=info

# ==========================================
# 🔑 JWT CONFIGURATION (F1)
# ==========================================

# JWT Algorithm (RS256 required for production security)
JWT_ALGORITHM=RS256

# JWT Key ID (for JWKS endpoint)
JWT_KEY_ID=oauth2-key-v1

# JWT Issuer (should match your OAuth2 server URL)
JWT_ISSUER=https://byteberry.auth.jrmdev.org

# JWT Audience (comma-separated list of services that will validate tokens)
JWT_AUDIENCE=byteberry-api,byteberry-bff

# ==========================================
# 🔒 SECURITY CONFIGURATION (F1)
# ==========================================

# CORS allowed origins (comma-separated)
# Development: localhost with common development ports
# Production: only your actual frontend domains
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://byteberry.app.jrmdev.org
