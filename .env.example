# ==============================================
# ByteBerry OAuth2 Service
# ==============================================

# ------------------------------------------------
# Node.js Environment
# ------------------------------------------------
NODE_ENV=development

# ------------------------------------------------
# Server Configuration
# ------------------------------------------------
PORT=4000

# ------------------------------------------------
# Logging Configuration
# ------------------------------------------------
LOG_LEVEL=info

# ------------------------------------------------
# Security Configuration
# ------------------------------------------------
CORS_ORIGINS=http://localhost:5173,https://ByteBerry.app.jrmdev.org

# ------------------------------------------------
# Application Metadata
# ------------------------------------------------
SERVICE_NAME=ByteBerry-OAuth2

# ------------------------------------------------
# Private key for signing JWTs (PEM format with \n for newlines)
# ------------------------------------------------
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"

# ------------------------------------------------
# Public key for verifying JWTs (PEM format with \n for newlines)
# ------------------------------------------------
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----"

# ------------------------------------------------
# Key identifier (optional, defaults to 'default-key-1')
# ------------------------------------------------
JWT_KEY_ID=default-key-1

# ------------------------------------------------
# OAuth2 Configuration
# ------------------------------------------------
OAUTH2_ISSUER=byteberry-oauth2
JWT_AUDIENCE=byteberry-expenses,byteberry-bff
TOKEN_EXPIRES_IN=900

# ------------------------------------------------
# Database Configuration
# ------------------------------------------------
DATABASE_URL="postgresql://oauth2_user:oauth2_pass@localhost:5432/byteberry_oauth2_dev?schema=public"
POSTGRES_USER=oauth2_user
POSTGRES_PASSWORD=oauth2_pass
POSTGRES_DB=byteberry_oauth2_dev
