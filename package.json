{
  "name": "oauth2",
  "version": "1.3.3",
  "description": "Servidor OAuth2 con Authorization Code + PKCE, JWT RS256, refresh tokens y JWKS",
  "main": "dist/app.js",
  "scripts": {
    "audit:fix": "pnpm audit --fix",
    "audit": "pnpm audit",
    "build": "tsc -p tsconfig.build.json",
    "ci:all": "pnpm type-check && pnpm lint && pnpm audit && pnpm build && pnpm test:coverage",
    "clean": "rm -rf dist coverage *.tsbuildinfo",
    "commit": "git-cz",
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/app.ts",
    "docker:build": "./scripts/docker-build.sh dev",
    "docker:run": "docker run --rm -p 4000:4000 -e NODE_ENV=development byteberry-oauth2:dev",
    "docker:test": "./scripts/docker-test.sh test",
    "lint:fix": "eslint . --fix",
    "lint": "eslint .",
    "postbuild": "tsc-alias -p tsconfig.build.json",
    "prebuild": "npm run clean",
    "release:test": "./scripts/test.release.sh",
    "release": "semantic-release",
    "start": "node dist/app.js",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose",
    "test:watch": "jest --watch",
    "test": "jest --silent",
    "type-check": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.18.0",
    "pnpm": ">=10.18.1"
  },
  "keywords": [],
  "author": "Jesus Ruvalcaba",
  "license": "MIT",
  "packageManager": "pnpm@10.18.1",
  "pnpm": {
    "overrides": {
      "tmp": ">=0.2.4"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.36.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.5.2",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.4.0",
    "jest": "^30.1.3",
    "jest-watch-typeahead": "^2.2.2",
    "jiti": "^2.6.0",
    "prettier": "^3.6.2",
    "semantic-release": "^24.2.9",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.1"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "env-var": "^7.5.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "winston": "^3.18.3",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      "@semantic-release/github",
      [
        "@semantic-release/git",
        {
          "assets": [
            "CHANGELOG.md",
            "package.json"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
        }
      ]
    ]
  }
}
