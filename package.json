{
	"name": "oauth2-server",
	"version": "1.1.0",
	"description": "Servidor OAuth2 con Authorization Code + PKCE, JWT RS256, refresh tokens y JWKS",
	"main": "dist/app.js",
	"type": "module",
	"author": "",
	"license": "ISC",
	"packageManager": "pnpm@10.20.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/JRuvalcabaFSD/ByteBerry-OAuth2"
	},
	"engines": {
		"node": ">=20.21.1",
		"npm": ">=10.20.0"
	},
	"scripts": {
		"audit:fix": "pnpm audit fix",
		"audit": "pnpm audit",
		"build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
		"ci:all": "./scripts/test.release.sh",
		"clean": "rm -rf dist",
		"commit": "git-cz",
		"dev": "tsx --watch src/app.ts",
		"docker:build": "TEST_VERSION=2.0.0 ./scripts/docker-build.sh",
		"docker:run": "docker run --rm -p 4000:4000 --env-file .env jruvalcabafsd/byteberry-oauth2:dev",
		"docs:build": "pnpm run docs:clean && pnpm run docs:generate",
		"docs:ci": "pnpm run docs:build && echo 'Documentation generated successfully'",
		"docs:clean": "rimraf docs",
		"docs:dev": "pnpm run docs:build && pnpm run docs:serve",
		"docs:generate": "typedoc --options typedoc.json",
		"docs:serve": "http-server docs -p 8080 -o -c-1",
		"docs:watch": "nodemon --watch src --ext ts --exec \"pnpm run docs:build\"",
		"generate:keys": "node scripts/generate-keys.mjs",
		"generate:pkce": " node ./scripts/generate-pkce.cjs",
		"lint:fix": "eslint . --fix",
		"lint": "eslint .",
		"prebuild": "pnpm run clean",
		"quality": "pnpm type-check && pnpm lint && pnpm audit && pnpm build && pnpm test:all",
		"release": "semantic-release",
		"start": "node dist/src/app.js",
		"test:all": "vitest tests/unit tests/integration",
		"test:coverage": "vitest --coverage",
		"test:integration": "vitest --config vitest.integration.config.ts",
		"test:ui": "vitest --ui",
		"test:unit": "vitest tests/unit",
		"test:watch": "vitest --watch",
		"test": "vitest",
		"type-check": "tsc --noEmit -p tsconfig.check.json"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.1.0",
		"@commitlint/config-conventional": "^20.0.0",
		"@eslint/js": "^9.39.1",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/git": "^10.0.1",
		"@types/bcrypt": "^6.0.0",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/morgan": "^1.9.10",
		"@types/node": "^24.10.1",
		"@types/pg": "^8.15.6",
		"@types/qs": "^6.14.0",
		"@types/supertest": "^6.0.3",
		"@vitest/coverage-v8": "^4.0.15",
		"@vitest/ui": "^4.0.15",
		"commitizen": "^4.3.1",
		"cz-conventional-changelog": "^3.3.0",
		"eslint": "^9.39.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.4",
		"globals": "^16.5.0",
		"http-server": "^14.1.1",
		"jiti": "^2.6.1",
		"jsdoc": "^4.0.5",
		"prettier": "^3.7.3",
		"prisma": "^7.1.0",
		"semantic-release": "^25.0.2",
		"supertest": "^7.1.4",
		"ts-node": "^10.9.2",
		"tsc-alias": "^1.8.16",
		"tsx": "^4.21.0",
		"typedoc": "^0.28.15",
		"typedoc-plugin-markdown": "^4.9.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.48.1",
		"vite-tsconfig-paths": "^5.1.4",
		"vitest": "^4.0.15"
	},
	"dependencies": {
		"@prisma/adapter-pg": "^7.1.0",
		"@prisma/client": "^7.1.0",
		"bcrypt": "^6.0.0",
		"cors": "^2.8.5",
		"dotenv": "16.4.5",
		"env-var": "^7.5.0",
		"express": "^5.2.1",
		"helmet": "^8.1.0",
		"jsonwebtoken": "^9.0.2",
		"pg": "^8.16.3",
		"rimraf": "^6.1.2",
		"winston": "^3.18.3",
		"winston-daily-rotate-file": "^5.0.0"
	},
	"config": {
		"commitizen": {
			"path": "./node_modules/cz-conventional-changelog"
		}
	},
	"release": {
		"branches": [
			"main"
		],
		"plugins": [
			[
				"@semantic-release/commit-analyzer",
				{
					"preset": "angular",
					"releaseRules": [
						{
							"type": "fix",
							"release": "patch"
						},
						{
							"type": "feat",
							"release": "minor"
						},
						{
							"type": "chore",
							"scope": "!release",
							"release": "minor"
						},
						{
							"breaking": true,
							"release": "major"
						}
					]
				}
			],
			"@semantic-release/release-notes-generator",
			"@semantic-release/changelog",
			[
				"@semantic-release/npm",
				{
					"npmPublish": false
				}
			],
			"@semantic-release/github",
			[
				"@semantic-release/git",
				{
					"assets": [
						"CHANGELOG.md",
						"package.json",
						"pnpm-lock.yaml"
					],
					"message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}",
					"skipCi": true,
					"gitRemote": "git@github.com:JRuvalcabaFSD/ByteBerry-OAuth2.git"
				}
			]
		]
	}
}
